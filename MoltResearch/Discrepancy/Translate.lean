  have hR : apSumOffset (fun k => f (k + (a % d))) d (m + a / d) n =
      apSum (fun k => f (k + ((m + a / d) * d + a % d))) d n := by
    simp [apSumOffset_eq_apSum_shift_add, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm]
