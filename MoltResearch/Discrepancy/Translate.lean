lemma apSumOffset_shift_add_eq_apSumOffset_div_mod (f : ℕ → ℤ) (a d m n : ℕ) (hd : d > 0) :
    apSumOffset (fun k => f (k + a)) d m n =
      apSumOffset (fun k => f (k + (a % d))) d (m + a / d) n := by
  -- Compute the adjusted translation constant.
