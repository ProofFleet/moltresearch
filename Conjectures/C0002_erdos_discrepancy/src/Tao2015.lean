theorem not_boundedDiscrepancy_of_unboundedDiscOffset_one_le (f : Ôäò ÔåÆ Ôäñ) {d m : Ôäò} (hd : 1 Ôëñ d)
    (hunb : UnboundedDiscOffset f d m) :
