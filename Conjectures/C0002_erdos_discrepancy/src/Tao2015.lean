import MoltResearch.Discrepancy

/-!
# Tao 2015: Erd┼Сs discrepancy theorem (Track C skeleton)

This module is **Conjectures-only**: it may contain `sorry`.

Hard goal for Track C automation: make

`lake build Conjectures.C0002_erdos_discrepancy.src.ErdosDiscrepancy`

compile cleanly, while providing *typed stage interfaces* for the Tao 2015 proof pipeline.

Design principles:
- Keep the surface small and stable (records + a few normal-form predicates).
- Avoid lemma sprawl in `MoltResearch/` (verified substrate lives elsewhere).
- Prefer explicit stage boundaries (`ReductionOutput`, `Stage2Output`, `Stage3Output`).

Note: The previous version of this file accrued a lot of autogenerated glue and became
non-compiling (duplicate declarations + simp loops). This rewrite restores a minimal,
compiling interface.
-/

namespace MoltResearch

namespace Tao2015

set_option autoImplicit false

/-!
## Fixed-step discrepancy normal forms

These are the Track C тАЬalong a fixed step `d`тАЭ analogues of the global predicates in
`MoltResearch.Discrepancy.Unbounded`.
-/

/-- `g` has bounded discrepancy along the fixed step `d`. -/
def BoundedDiscrepancyAlong (g : тДХ тЖТ тДд) (d : тДХ) : Prop :=
  тИГ B : тДХ, тИА n : тДХ, discrepancy g d n тЙд B

/-- `g` has unbounded discrepancy along the fixed step `d` (witness form). -/
def UnboundedDiscrepancyAlong (g : тДХ тЖТ тДд) (d : тДХ) : Prop :=
  тИА B : тДХ, тИГ n : тДХ, B < discrepancy g d n

/-- `g` has discrepancy at least `C` along the fixed step `d` (witness form). -/
def HasDiscrepancyAtLeastAlong (g : тДХ тЖТ тДд) (d : тДХ) (C : тДХ) : Prop :=
  тИГ n : тДХ, C < discrepancy g d n

/-- Unboundedness of a bundled offset discrepancy family. -/
def UnboundedDiscOffset (f : тДХ тЖТ тДд) (d m : тДХ) : Prop :=
  тИА B : тДХ, тИГ n : тДХ, B < discOffset f d m n

namespace UnboundedDiscrepancyAlong

/-- Classical equivalence: unboundedness along `d` is the negation of boundedness along `d`. -/
theorem iff_not_boundedDiscrepancyAlong (g : тДХ тЖТ тДд) (d : тДХ) :
    UnboundedDiscrepancyAlong g d тЖФ ┬м BoundedDiscrepancyAlong g d := by
  classical
  constructor
  ┬╖ intro hunb hb
    rcases hb with тЯиB, hBтЯй
    rcases hunb B with тЯиn, hnтЯй
    exact (not_lt_of_ge (hB n)) hn
  ┬╖ intro hnb
    intro B
    by_contra h
    have hB : тИА n : тДХ, discrepancy g d n тЙд B := by
      intro n
      refine le_of_not_gt ?_
      intro hgt
      exact h тЯиn, hgtтЯй
    exact hnb тЯиB, hBтЯй

end UnboundedDiscrepancyAlong

namespace HasDiscrepancyAtLeastAlong

/-- `тИА C, HasDiscrepancyAtLeastAlong g d C` is just `UnboundedDiscrepancyAlong g d`. -/
theorem forall_hasDiscrepancyAtLeastAlong_iff_unboundedDiscrepancyAlong (g : тДХ тЖТ тДд) (d : тДХ) :
    (тИА C : тДХ, HasDiscrepancyAtLeastAlong g d C) тЖФ UnboundedDiscrepancyAlong g d := by
  constructor
  ┬╖ intro h B
    exact h B
  ┬╖ intro hunb C
    exact hunb C

end HasDiscrepancyAtLeastAlong

/-!
## Global contexts (boundedness data)

These are small records bundling bounds in a consumer-friendly way.
They are intentionally *weak*: later stages can strengthen/replace them.
-/

/-- A global boundedness context for `f`, extracted from `BoundedDiscrepancy f`. -/
structure Context (f : тДХ тЖТ тДд) : Type where
  /-- A global bound. -/
  B : тДХ
  /-- Bound on homogeneous discrepancy (`discrepancy = natAbs(apSum)`). -/
  bound_discrepancy : тИА d n : тДХ, d > 0 тЖТ discrepancy f d n тЙд B
  /-- A convenient derived bound for offset discrepancy families. -/
  bound_discOffset_two_mul : тИА d m n : тДХ, d > 0 тЖТ discOffset f d m n тЙд 2 * B

namespace Context

/-- Build a `Context` from `BoundedDiscrepancy`.

Note: `BoundedDiscrepancy f` lives in `Prop`, while `Context f` is a `Type`, so we must use
classical choice rather than pattern matching on the existential witness.
-/
noncomputable def ofBoundedDiscrepancy (f : тДХ тЖТ тДд) (hb : BoundedDiscrepancy f) : Context f := by
  classical
  let B : тДХ := Classical.choose hb
  have hB : тИА d n : тДХ, d > 0 тЖТ Int.natAbs (apSum f d n) тЙд B := Classical.choose_spec hb
  refine
    { B := B
      bound_discrepancy := ?_
      bound_discOffset_two_mul := ?_ }
  ┬╖ intro d n hd
    -- `discrepancy` is definitionally `Int.natAbs (apSum ...)`.
    change Int.natAbs (apSum f d n) тЙд B
    exact hB d n hd
  ┬╖ intro d m n hd
    -- Offset sum is a difference of two prefix sums; use triangle inequality + the global bound.
    have hEq : apSum f d (m + n) + (- apSum f d m) = apSumOffset f d m n := by
      calc
        apSum f d (m + n) + (- apSum f d m)
            = apSum f d (m + n) - apSum f d m := by
                simp [sub_eq_add_neg]
        _ = apSumOffset f d m n :=
          (MoltResearch.apSumOffset_eq_sub (f := f) (d := d) (m := m) (n := n)).symm

    have htri :
        Int.natAbs (apSumOffset f d m n) тЙд
          Int.natAbs (apSum f d (m + n)) + Int.natAbs (apSum f d m) := by
      simpa [hEq, Int.natAbs_neg] using
        (Int.natAbs_add_le (apSum f d (m + n)) (- apSum f d m))

    have hsum :
        Int.natAbs (apSum f d (m + n)) + Int.natAbs (apSum f d m) тЙд B + B :=
      Nat.add_le_add (hB d (m + n) hd) (hB d m hd)

    have hfinal : Int.natAbs (apSumOffset f d m n) тЙд B + B :=
      le_trans htri hsum

    have : discOffset f d m n тЙд B + B := by
      change Int.natAbs (apSumOffset f d m n) тЙд B + B
      exact hfinal

    simpa [two_mul] using this

end Context

/-- Fixed-step analogue of `Context`: a bound on `discrepancy g d n` for all `n`. -/
structure ContextAlong (g : тДХ тЖТ тДд) (d : тДХ) : Type where
  B : тДХ
  bound_discrepancy : тИА n : тДХ, discrepancy g d n тЙд B

namespace ContextAlong

/-- Build a `ContextAlong` from `BoundedDiscrepancyAlong`.

As with `Context.ofBoundedDiscrepancy`, we use classical choice to extract the witness.
-/
noncomputable def ofBoundedDiscrepancyAlong {g : тДХ тЖТ тДд} {d : тДХ} (hb : BoundedDiscrepancyAlong g d) :
    ContextAlong g d := by
  classical
  let B : тДХ := Classical.choose hb
  have hB : тИА n : тДХ, discrepancy g d n тЙд B := Classical.choose_spec hb
  exact тЯиB, hBтЯй

/-- Turn a `ContextAlong` back into `BoundedDiscrepancyAlong`. -/
theorem toBoundedDiscrepancyAlong {g : тДХ тЖТ тДд} {d : тДХ} (ctx : ContextAlong g d) :
    BoundedDiscrepancyAlong g d := by
  exact тЯиctx.B, ctx.bound_discrepancyтЯй

end ContextAlong

/-!
## Stage 1: shift reduction output

Stage 1 packages a derived sign sequence `g` (typically a shift of `f`), together with a fixed
step size `d` and an offset parameter `m`, plus *transport contracts* between discrepancy
statements about `g` and offset discrepancy statements about `f`.

This is deliberately an IO-style record: downstream stages should consume the record rather than
re-proving ad-hoc rewrites.
-/

structure ReductionOutput (f : тДХ тЖТ тДд) : Type where
  /-- Fixed step size for the reduced locus. -/
  d : тДХ
  /-- The step size is positive.

  Most discrepancy statements (including `BoundedDiscrepancy`) only quantify over `d > 0`.
  We store this here so later stages can use it without threading it separately.
  -/
  hd : d > 0
  /-- Offset parameter bundling the tail `m*d`. -/
  m : тДХ
  /-- Reduced sign sequence. -/
  g : тДХ тЖТ тДд
  /-- Proof that `g` is a sign sequence. -/
  hg : IsSignSequence g
  /-- Defining equation: `g k = f (k + m*d)`.

  We keep this explicit because it is frequently used for rewriting.
  -/
  g_eq : тИА k : тДХ, g k = f (k + m * d)
  /-- Transfer contract: a uniform bound on `discOffset f d m` bounds `discrepancy g d`. -/
  contract_discrepancy_le :
    тИА B : тДХ, (тИА n : тДХ, discOffset f d m n тЙд B) тЖТ тИА n : тДХ, discrepancy g d n тЙд B

namespace ReductionOutput

variable {f : тДХ тЖТ тДд}

/-- Canonical Stage-1 reduction: shift `f` by `m*d`.

This is the тАЬpure index gymnasticsтАЭ step: it defines
`g k := f (k + m*d)`.

The transport contracts are left as `sorry` stubs for now (Conjectures-only).
-/
def ofShift (f : тДХ тЖТ тДд) (hf : IsSignSequence f) (d m : тДХ) (hd : d > 0) : ReductionOutput f := by
  classical
  refine
    { d := d
      hd := hd
      m := m
      g := fun k => f (k + m * d)
      hg := ?_
      g_eq := ?_
      contract_discrepancy_le := ?_ }
  ┬╖ intro k
    simpa using hf (k + m * d)
  ┬╖ intro k
    rfl
  ┬╖ intro B hB n
    -- Normalize the reduced discrepancy to the bundled offset discrepancy wrapper.
    have hrewrite :
        discrepancy (fun k => f (k + m * d)) d n = discOffset f d m n := by
      -- `discrepancy_shift_mul_simp` is the standard normal form for shifts by `m*d`.
      simpa using
        (discrepancy_shift_mul_simp (f := f) (m := m) (d := d) (n := n))
    -- Now discharge the bound using the supplied uniform `discOffset` bound.
    simpa [hrewrite] using hB n

/-- Consumer-facing rewrite: discrepancy of the reduced sequence equals bundled offset discrepancy.

This is the key normal-form bridge used by later stages.
-/
theorem discrepancy_eq_discOffset_via_contract (out : ReductionOutput f) (n : тДХ) :
    discrepancy out.g out.d n = discOffset f out.d out.m n := by
  -- `out.g_eq` identifies `out.g` with the canonical shift `fun k тЖж f (k + m*d)`.
  have hgfun : out.g = fun k => f (k + out.m * out.d) := by
    funext k
    simpa [out.g_eq]
  -- Now normalize discrepancy of a shift by `m*d`.
  simpa [hgfun] using
    (discrepancy_shift_mul_simp (f := f) (m := out.m) (d := out.d) (n := n))

/-- Bounded discrepancy along the reduced step is equivalent to a uniform bound on the bundled offset
discrepancy family.

This is a tiny packaging lemma: it lets consumers switch between the fixed-step normal form
(`discrepancy out.g out.d`) and the bundled offset normal form (`discOffset f out.d out.m`).
-/
theorem boundedDiscrepancyAlong_iff_exists_forall_discOffset_le (out : ReductionOutput f) :
    BoundedDiscrepancyAlong out.g out.d тЖФ
      тИГ B : тДХ, тИА n : тДХ, discOffset f out.d out.m n тЙд B := by
  unfold BoundedDiscrepancyAlong
  constructor
  ┬╖ rintro тЯиB, hBтЯй
    refine тЯиB, ?_тЯй
    intro n
    have h : discrepancy out.g out.d n тЙд B := hB n
    simpa [out.discrepancy_eq_discOffset_via_contract (f := f) (n := n)] using h
  ┬╖ rintro тЯиB, hBтЯй
    refine тЯиB, ?_тЯй
    intro n
    have h : discOffset f out.d out.m n тЙд B := hB n
    simpa [out.discrepancy_eq_discOffset_via_contract (f := f) (n := n)] using h

/-- Stage-1 witness transport: reduced discrepancy-at-least is an affine-tail witness for `f`.

The affine nucleus is `apSumFrom f (m*d) d n`.
-/
theorem hasDiscrepancyAtLeastAlong_iff_exists_natAbs_apSumFrom_mul_gt (out : ReductionOutput f)
    (C : тДХ) :
    HasDiscrepancyAtLeastAlong out.g out.d C тЖФ
      тИГ n : тДХ, Int.natAbs (apSumFrom f (out.m * out.d) out.d n) > C := by
  unfold HasDiscrepancyAtLeastAlong
  constructor
  ┬╖ rintro тЯиn, hnтЯй
    have hn' : C < discOffset f out.d out.m n := by
      simpa [discrepancy_eq_discOffset_via_contract (f := f) (out := out) (n := n)] using hn
    have hsum : apSumOffset f out.d out.m n = apSumFrom f (out.m * out.d) out.d n := by
      simpa using
        (apSumFrom_tail_eq_apSumOffset_shift_add (f := f) (a := 0) (d := out.d) (m := out.m)
            (n := n)).symm

    have hn0 := hn'
    unfold discOffset at hn0
    have hnat :
        Int.natAbs (apSumOffset f out.d out.m n) =
          Int.natAbs (apSumFrom f (out.m * out.d) out.d n) := by
      simpa using congrArg Int.natAbs hsum
    rw [hnat] at hn0
    exact тЯиn, hn0тЯй

  ┬╖ rintro тЯиn, hnтЯй
    have hsum : apSumFrom f (out.m * out.d) out.d n = apSumOffset f out.d out.m n := by
      simpa using
        (apSumFrom_tail_eq_apSumOffset_shift_add (f := f) (a := 0) (d := out.d) (m := out.m)
            (n := n))

    have hn0 := hn
    have hnat :
        Int.natAbs (apSumFrom f (out.m * out.d) out.d n) =
          Int.natAbs (apSumOffset f out.d out.m n) := by
      simpa using congrArg Int.natAbs hsum
    rw [hnat] at hn0

    have hn' : C < discOffset f out.d out.m n := by
      change C < Int.natAbs (apSumOffset f out.d out.m n)
      exact hn0

    refine тЯиn, ?_тЯй
    have heq := discrepancy_eq_discOffset_via_contract (f := f) (out := out) (n := n)
    simpa [heq] using hn'

/-- Unboundedness of reduced discrepancy is equivalent to unboundedness of the bundled offset family.

The suffix `_lt` is legacy: the witness is `B < ...` (i.e. тАЬgreater than BтАЭ).
-/
theorem unboundedDiscrepancyAlong_iff_forall_exists_discOffset_lt (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d тЖФ (тИА B : тДХ, тИГ n : тДХ, B < discOffset f out.d out.m n) := by
  constructor
  ┬╖ intro hunb B
    rcases hunb B with тЯиn, hnтЯй
    refine тЯиn, ?_тЯй
    simpa [discrepancy_eq_discOffset_via_contract (out := out) (n := n)] using hn
  ┬╖ intro hunb B
    rcases hunb B with тЯиn, hnтЯй
    refine тЯиn, ?_тЯй
    simpa [discrepancy_eq_discOffset_via_contract (out := out) (n := n)] using hn

/-- Alias of `unboundedDiscrepancyAlong_iff_forall_exists_discOffset_lt` with a suffix matching the
inequality direction (`B < ...`). -/
theorem unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d тЖФ (тИА B : тДХ, тИГ n : тДХ, B < discOffset f out.d out.m n) := by
  simpa using (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_lt (f := f) (out := out))

/-- Packaged predicate form: reduced-step unbounded discrepancy is equivalent to unboundedness of the
bundled offset discrepancy family for `f`.
-/
theorem unboundedDiscrepancyAlong_iff_unboundedDiscOffset (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d тЖФ UnboundedDiscOffset f out.d out.m := by
  simpa [UnboundedDiscOffset] using
    (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (f := f) (out := out))

/-- Nucleus-level variant of `unboundedDiscrepancyAlong_iff_forall_exists_discOffset_lt`. -/
theorem unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumOffset_lt (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d тЖФ
      (тИА B : тДХ, тИГ n : тДХ, B < Int.natAbs (apSumOffset f out.d out.m n)) := by
  constructor
  ┬╖ intro hunb
    have hdisc : тИА B : тДХ, тИГ n : тДХ, B < discOffset f out.d out.m n :=
      (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_lt (f := f) (out := out)).1 hunb
    intro B
    rcases hdisc B with тЯиn, hnтЯй
    exact тЯиn, hnтЯй
  ┬╖ intro hunb
    refine
      (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_lt (f := f) (out := out)).2 ?_
    intro B
    rcases hunb B with тЯиn, hnтЯй
    exact тЯиn, hnтЯй

/-- Alias of `unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumOffset_lt` with a suffix matching
the inequality direction (`B < ...`). -/
theorem unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumOffset_gt (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d тЖФ
      (тИА B : тДХ, тИГ n : тДХ, B < Int.natAbs (apSumOffset f out.d out.m n)) := by
  simpa using
    (unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumOffset_lt (f := f) (out := out))

/-- If the bundled offset discrepancies are unbounded, then `f` cannot have globally bounded discrepancy. -/
theorem not_boundedDiscrepancy_of_forall_exists_discOffset_gt (out : ReductionOutput f)
    (hunb : тИА B : тДХ, тИГ n : тДХ, B < discOffset f out.d out.m n) :
    ┬м BoundedDiscrepancy f := by
  intro hb
  -- Turn global boundedness into a reusable `Context`, then contradict the unbounded witness.
  let ctx : Context f := Context.ofBoundedDiscrepancy (f := f) hb
  have hbound : тИА n : тДХ, discOffset f out.d out.m n тЙд 2 * ctx.B := by
    intro n
    simpa using
      (ctx.bound_discOffset_two_mul (f := f) (d := out.d) (m := out.m) (n := n) out.hd)
  rcases hunb (2 * ctx.B) with тЯиn, hnтЯй
  exact (not_lt_of_ge (hbound n)) hn

end ReductionOutput

/-- If some offset discrepancy family is unbounded, then `f` cannot have globally bounded discrepancy.

This is the global (nonтАУStage-1-specific) contrapositive used by later stages: global bounded
discrepancy implies a uniform bound on every `discOffset f d m`, so unboundedness of any one such
family yields a contradiction.
-/
theorem not_boundedDiscrepancy_of_forall_exists_discOffset_gt (f : тДХ тЖТ тДд) {d m : тДХ} (hd : d > 0)
    (hunb : тИА B : тДХ, тИГ n : тДХ, B < discOffset f d m n) :
    ┬м BoundedDiscrepancy f := by
  intro hb
  -- Turn global boundedness into a reusable `Context`, then contradict the unbounded witness.
  let ctx : Context f := Context.ofBoundedDiscrepancy (f := f) hb
  have hbound : тИА n : тДХ, discOffset f d m n тЙд 2 * ctx.B := by
    intro n
    simpa using (ctx.bound_discOffset_two_mul (f := f) (d := d) (m := m) (n := n) hd)
  rcases hunb (2 * ctx.B) with тЯиn, hnтЯй
  exact (not_lt_of_ge (hbound n)) hn

/-- If an offset discrepancy family is unbounded (packaged form), then `f` cannot have globally
bounded discrepancy.

This is just `not_boundedDiscrepancy_of_forall_exists_discOffset_gt` with `UnboundedDiscOffset`
unfolded.
-/
theorem not_boundedDiscrepancy_of_unboundedDiscOffset (f : тДХ тЖТ тДд) {d m : тДХ} (hd : d > 0)
    (hunb : UnboundedDiscOffset f d m) :
    ┬м BoundedDiscrepancy f := by
  refine
    Tao2015.not_boundedDiscrepancy_of_forall_exists_discOffset_gt (f := f) (d := d) (m := m) hd ?_
  simpa [UnboundedDiscOffset] using hunb

end Tao2015

end MoltResearch
