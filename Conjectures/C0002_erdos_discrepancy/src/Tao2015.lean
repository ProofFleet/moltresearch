/-!
# Tao 2015: ErdŇĎs discrepancy theorem (Track C skeleton)

This module is **Conjectures-only**: it may contain axiom stubs and temporary placeholders.

At present, the only non-verified assumption is the Stage-2 axiom in
`Conjectures.C0002_erdos_discrepancy.src.TrackCStage2Stub`.

Hard goal for Track C automation: make

`lake build Conjectures.C0002_erdos_discrepancy.src.ErdosDiscrepancy`

compile cleanly, while providing *typed stage interfaces* for the Tao 2015 proof pipeline.

Design principles:
- Keep the surface small and stable (records + a few normal-form predicates).
- Avoid lemma sprawl in `MoltResearch/` (verified substrate lives elsewhere).
- Prefer explicit stage boundaries (`ReductionOutput`, `Stage2Output`, `Stage3Output`).

Note: The previous version of this file accrued a lot of autogenerated glue and became
non-compiling (duplicate declarations + simp loops). This rewrite restores a minimal,
compiling interface.
-/

namespace MoltResearch

namespace Tao2015

set_option autoImplicit false

/-!
## Fixed-step discrepancy normal forms

These are the Track C ‚Äúalong a fixed step `d`‚ÄĚ analogues of the global predicates in
`MoltResearch.Discrepancy.Unbounded`.
-/

/-- `g` has bounded discrepancy along the fixed step `d`. -/
def BoundedDiscrepancyAlong (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) : Prop :=
  ‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, discrepancy g d n ‚Č§ B

/-- Nucleus normal form for `BoundedDiscrepancyAlong`.

Normal form:
`‚ąÉ B, ‚ąÄ n, Int.natAbs (apSum g d n) ‚Č§ B`.

This is a lightweight rewrite of the definition of `BoundedDiscrepancyAlong` using the definitional
identity `discrepancy g d n = Int.natAbs (apSum g d n)`.
-/
theorem boundedDiscrepancyAlong_iff_exists_forall_natAbs_apSum_le (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    BoundedDiscrepancyAlong g d ‚ÜĒ (‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, Int.natAbs (apSum g d n) ‚Č§ B) := by
  constructor
  ¬∑ rintro ‚ü®B, hB‚ü©
    refine ‚ü®B, ?_‚ü©
    intro n
    have hn : discrepancy g d n ‚Č§ B := hB n
    unfold discrepancy at hn
    exact hn
  ¬∑ rintro ‚ü®B, hB‚ü©
    refine ‚ü®B, ?_‚ü©
    intro n
    have hn : Int.natAbs (apSum g d n) ‚Č§ B := hB n
    unfold discrepancy
    exact hn

/-- Stable-wrapper normal form for `BoundedDiscrepancyAlong`.

Normal form:
`‚ąÉ B, ‚ąÄ n, discAlong g d n ‚Č§ B`.

This is a tiny packaging lemma: it lets later stages rewrite bounds in terms of the stable wrapper
`discAlong`, rather than the raw `discrepancy` definition.
-/
theorem boundedDiscrepancyAlong_iff_exists_forall_discAlong_le (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    BoundedDiscrepancyAlong g d ‚ÜĒ (‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, discAlong g d n ‚Č§ B) := by
  constructor
  ¬∑ rintro ‚ü®B, hB‚ü©
    refine ‚ü®B, ?_‚ü©
    intro n
    simpa [discAlong_eq_discrepancy] using hB n
  ¬∑ rintro ‚ü®B, hB‚ü©
    refine ‚ü®B, ?_‚ü©
    intro n
    simpa [discAlong_eq_discrepancy] using hB n

/-- `g` has unbounded discrepancy along the fixed step `d` (witness form). -/
def UnboundedDiscrepancyAlong (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) : Prop :=
  ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < discrepancy g d n

/-- Negation-normal-form equivalence: fixed-step unboundedness is the negation of fixed-step boundedness.

This lemma is intentionally tiny but useful when stage boundaries trade between witness forms and
boundedness hypotheses.
-/
theorem unboundedDiscrepancyAlong_iff_not_boundedDiscrepancyAlong (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    UnboundedDiscrepancyAlong g d ‚ÜĒ ¬¨ BoundedDiscrepancyAlong g d := by
  classical
  constructor
  ¬∑ intro hunb hbd
    rcases hbd with ‚ü®B, hB‚ü©
    rcases hunb B with ‚ü®n, hn‚ü©
    exact (not_lt_of_ge (hB n)) hn
  ¬∑ intro hnot B
    by_contra hcontra
    have hle : ‚ąÄ n : ‚Ąē, discrepancy g d n ‚Č§ B := by
      intro n
      have hnotlt : ¬¨ B < discrepancy g d n := (not_exists.mp hcontra) n
      have hnotgt : ¬¨ discrepancy g d n > B := by
        simpa [gt_iff_lt] using hnotlt
      exact le_of_not_gt hnotgt
    exact hnot ‚ü®B, hle‚ü©

/-- Inequality-direction variant of `UnboundedDiscrepancyAlong`, written as `discrepancy ... > B`.

Many consumers prefer this normal form so they can `simp [gt_iff_lt]` at the call site.
-/
theorem unboundedDiscrepancyAlong_iff_forall_exists_discrepancy_gt' (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    UnboundedDiscrepancyAlong g d ‚ÜĒ (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, discrepancy g d n > B) := by
  constructor
  ¬∑ intro hunb B
    rcases hunb B with ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©
  ¬∑ intro h B
    rcases h B with ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©

/-- Inequality-direction variant of `UnboundedDiscrepancyAlong`, written using the stable wrapper
`discAlong`.

Normal form:
`‚ąÄ B, ‚ąÉ n, discAlong g d n > B`.

This is `unboundedDiscrepancyAlong_iff_forall_exists_discrepancy_gt'` rewritten using
`discAlong_eq_discrepancy`.
-/
theorem unboundedDiscrepancyAlong_iff_forall_exists_discAlong_gt' (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    UnboundedDiscrepancyAlong g d ‚ÜĒ (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, discAlong g d n > B) := by
  simpa [discAlong_eq_discrepancy] using
    (unboundedDiscrepancyAlong_iff_forall_exists_discrepancy_gt' (g := g) (d := d))

/-- Nucleus normal form for `UnboundedDiscrepancyAlong`.

Normal form:
`‚ąÄ B, ‚ąÉ n, Int.natAbs (apSum g d n) > B`.

This is a lightweight rewrite of `unboundedDiscrepancyAlong_iff_forall_exists_discrepancy_gt'`
using the definitional equality `discrepancy g d n = Int.natAbs (apSum g d n)`.
-/
theorem unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSum_gt' (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    UnboundedDiscrepancyAlong g d ‚ÜĒ (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, Int.natAbs (apSum g d n) > B) := by
  constructor
  ¬∑ intro hunb B
    rcases hunb B with ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    -- `discrepancy g d n` is definitionally `Int.natAbs (apSum g d n)`.
    unfold discrepancy at hn
    exact hn
  ¬∑ intro h B
    rcases h B with ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    -- Unfold `discrepancy`, then use the nucleus witness.
    unfold discrepancy
    exact hn

namespace UnboundedDiscrepancyAlong

/-- Witness-positivity: in the unboundedness normal form
`‚ąÄ B, ‚ąÉ n, discrepancy g d n > B`, any witness length `n` is automatically positive.

Reason: `discrepancy g d 0 = 0`.
-/
theorem forall_exists_discrepancy_gt'_witness_pos {g : ‚Ąē ‚Üí ‚Ą§} {d : ‚Ąē}
    (hunb : UnboundedDiscrepancyAlong g d) :
    ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, n > 0 ‚ąß discrepancy g d n > B := by
  intro B
  rcases
      (unboundedDiscrepancyAlong_iff_forall_exists_discrepancy_gt' (g := g) (d := d)).1 hunb B with
    ‚ü®n, hn‚ü©
  have hn0 : n ‚Č† 0 := by
    intro h0
    subst h0
    have hn0' : discrepancy g d 0 > B := hn
    -- `simp` turns the discrepancy witness into `False` (since `discrepancy g d 0 = 0`).
    simp [discrepancy_zero] at hn0'
  exact ‚ü®n, Nat.pos_of_ne_zero hn0, hn‚ü©

/-- Witness-positivity: nucleus form of unboundedness, with `Int.natAbs (apSum ...) > B`. -/
theorem forall_exists_natAbs_apSum_gt'_witness_pos {g : ‚Ąē ‚Üí ‚Ą§} {d : ‚Ąē}
    (hunb : UnboundedDiscrepancyAlong g d) :
    ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, n > 0 ‚ąß Int.natAbs (apSum g d n) > B := by
  intro B
  rcases forall_exists_discrepancy_gt'_witness_pos (g := g) (d := d) hunb B with ‚ü®n, hnpos, hn‚ü©
  refine ‚ü®n, hnpos, ?_‚ü©
  -- Avoid simp loops: `discrepancy` is definitional.
  have hn' := hn
  unfold discrepancy at hn'
  exact hn'

/-- Witness-positivity: stable-wrapper form of unboundedness, with `discAlong g d n > B`.

This is `forall_exists_discrepancy_gt'_witness_pos` rewritten using `discAlong_eq_discrepancy`.
-/
theorem forall_exists_discAlong_gt'_witness_pos {g : ‚Ąē ‚Üí ‚Ą§} {d : ‚Ąē}
    (hunb : UnboundedDiscrepancyAlong g d) :
    ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, n > 0 ‚ąß discAlong g d n > B := by
  intro B
  rcases forall_exists_discrepancy_gt'_witness_pos (g := g) (d := d) hunb B with ‚ü®n, hnpos, hn‚ü©
  refine ‚ü®n, hnpos, ?_‚ü©
  simpa [discAlong_eq_discrepancy] using hn

end UnboundedDiscrepancyAlong

/-- `g` has discrepancy at least `C` along the fixed step `d` (witness form). -/
def HasDiscrepancyAtLeastAlong (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) (C : ‚Ąē) : Prop :=
  ‚ąÉ n : ‚Ąē, C < discrepancy g d n

/-- Inequality-direction variant of `HasDiscrepancyAtLeastAlong`, written as `discrepancy ... > C`.

Many consumers prefer this normal form so they can `simp [gt_iff_lt]` at the call site.
-/
theorem hasDiscrepancyAtLeastAlong_iff_exists_discrepancy_gt' (g : ‚Ąē ‚Üí ‚Ą§) (d C : ‚Ąē) :
    HasDiscrepancyAtLeastAlong g d C ‚ÜĒ (‚ąÉ n : ‚Ąē, discrepancy g d n > C) := by
  constructor
  ¬∑ rintro ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©
  ¬∑ rintro ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©

/-- Stable-wrapper normal form for `HasDiscrepancyAtLeastAlong`.

Normal form:
`‚ąÉ n, discAlong g d n > C`.

This is `hasDiscrepancyAtLeastAlong_iff_exists_discrepancy_gt'` rewritten using
`discAlong_eq_discrepancy`.
-/
theorem hasDiscrepancyAtLeastAlong_iff_exists_discAlong_gt' (g : ‚Ąē ‚Üí ‚Ą§) (d C : ‚Ąē) :
    HasDiscrepancyAtLeastAlong g d C ‚ÜĒ (‚ąÉ n : ‚Ąē, discAlong g d n > C) := by
  simpa [discAlong_eq_discrepancy] using
    (hasDiscrepancyAtLeastAlong_iff_exists_discrepancy_gt' (g := g) (d := d) (C := C))

/-- Nucleus normal form for `HasDiscrepancyAtLeastAlong`.

Normal form:
`‚ąÉ n, Int.natAbs (apSum g d n) > C`.

This is a lightweight rewrite of `hasDiscrepancyAtLeastAlong_iff_exists_discrepancy_gt'` using the
definitional equality `discrepancy g d n = Int.natAbs (apSum g d n)`.
-/
theorem hasDiscrepancyAtLeastAlong_iff_exists_natAbs_apSum_gt' (g : ‚Ąē ‚Üí ‚Ą§) (d C : ‚Ąē) :
    HasDiscrepancyAtLeastAlong g d C ‚ÜĒ (‚ąÉ n : ‚Ąē, Int.natAbs (apSum g d n) > C) := by
  constructor
  ¬∑ rintro ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    unfold discrepancy at hn
    exact hn
  ¬∑ rintro ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    unfold discrepancy
    exact hn

/-- Unboundedness of a bundled offset discrepancy family. -/
def UnboundedDiscOffset (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) : Prop :=
  ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < discOffset f d m n

/-- Inequality-direction variant of `UnboundedDiscOffset`, written as `discOffset ... > B`.

Many consumers prefer this normal form so they can `simp [gt_iff_lt]` at the call site.
-/
theorem unboundedDiscOffset_iff_forall_exists_discOffset_gt' (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, discOffset f d m n > B) := by
  constructor
  ¬∑ intro hunb B
    rcases hunb B with ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©
  ¬∑ intro h B
    rcases h B with ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©

/-- Witness-positivity variant of `UnboundedDiscOffset`.

Since `discOffset f d m 0 = 0`, any witness satisfying `discOffset f d m n > B` must have
`n > 0`.

This is often the most convenient normal form for downstream stages that want to avoid reasoning
about the trivial `n = 0` case.
-/
theorem unboundedDiscOffset_iff_forall_exists_discOffset_gt'_witness_pos (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ
      (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, n > 0 ‚ąß discOffset f d m n > B) := by
  constructor
  ¬∑ intro hunb B
    rcases hunb B with ‚ü®n, hn‚ü©
    have hn0 : n ‚Č† 0 := by
      intro h0
      subst h0
      have : ¬¨ B < discOffset f d m 0 := by
        simp
      exact this hn
    exact ‚ü®n, Nat.pos_of_ne_zero hn0, hn‚ü©
  ¬∑ intro h B
    rcases h B with ‚ü®n, hnpos, hn‚ü©
    exact ‚ü®n, hn‚ü©

/-- Normal form: the affine-tail nucleus at start `m*d` is the bundled offset nucleus. -/
theorem apSumFrom_mul_eq_apSumOffset (f : ‚Ąē ‚Üí ‚Ą§) (d m n : ‚Ąē) :
    apSumFrom f (m * d) d n = apSumOffset f d m n := by
  unfold apSumFrom apSumOffset
  refine Finset.sum_congr rfl ?_
  intro i hi
  have hidx : m * d + (i + 1) * d = (m + i + 1) * d := by
    calc
      m * d + (i + 1) * d = (m + (i + 1)) * d := by
        simpa [Nat.add_mul] using (Nat.add_mul m (i + 1) d).symm
      _ = (m + i + 1) * d := by
        have hm : m + (i + 1) = m + i + 1 := by
          simpa using (Nat.add_assoc m i 1).symm
        simpa [hm]
  simpa [hidx]

/-- Normal form: offset discrepancy expressed directly using the affine-tail nucleus.

This avoids having to expand `discOffset` into `apSumOffset` and then rewrite to an `apSumFrom` tail
form by hand.
-/
theorem discOffset_eq_natAbs_apSumFrom_mul (f : ‚Ąē ‚Üí ‚Ą§) (d m n : ‚Ąē) :
    discOffset f d m n = Int.natAbs (apSumFrom f (m * d) d n) := by
  -- Rewrite `discOffset` to the bundled offset nucleus, then shuttle to the affine-tail form.
  calc
    discOffset f d m n = Int.natAbs (apSumOffset f d m n) := by
      exact discOffset_eq_natAbs_apSumOffset (f := f) (d := d) (m := m) (n := n)
    _ = Int.natAbs (apSumFrom f (m * d) d n) := by
      simpa using
        (congrArg Int.natAbs
            (apSumFrom_mul_eq_apSumOffset (f := f) (d := d) (m := m) (n := n))).symm

/-- Paper-notation normal form: the bundled offset nucleus `apSumOffset` is an interval sum.

This is a thin wrapper around `apSumOffset_eq_sum_Icc` (from `MoltResearch.Discrepancy`), with
`Int.natAbs` applied on both sides so it can be used directly in inequality goals.
-/
theorem natAbs_apSumOffset_eq_natAbs_sum_Icc (f : ‚Ąē ‚Üí ‚Ą§) (d m n : ‚Ąē) :
    Int.natAbs (apSumOffset f d m n) =
      Int.natAbs ((Finset.Icc (m + 1) (m + n)).sum (fun i => f (i * d))) := by
  -- Apply `Int.natAbs` to `apSumOffset_eq_sum_Icc` without invoking the simp engine.
  exact
    congrArg Int.natAbs (apSumOffset_eq_sum_Icc (f := f) (d := d) (m := m) (n := n))

/-- Paper-notation normal form: the bundled offset discrepancy wrapper `discOffset` is an interval sum.

This avoids having to unfold `discOffset` and then separately rewrite `apSumOffset` into an interval
sum.
-/
theorem discOffset_eq_natAbs_sum_Icc (f : ‚Ąē ‚Üí ‚Ą§) (d m n : ‚Ąē) :
    discOffset f d m n =
      Int.natAbs ((Finset.Icc (m + 1) (m + n)).sum (fun i => f (i * d))) := by
  calc
    discOffset f d m n = Int.natAbs (apSumOffset f d m n) :=
      discOffset_eq_natAbs_apSumOffset (f := f) (d := d) (m := m) (n := n)
    _ = Int.natAbs ((Finset.Icc (m + 1) (m + n)).sum (fun i => f (i * d))) :=
      natAbs_apSumOffset_eq_natAbs_sum_Icc (f := f) (d := d) (m := m) (n := n)

namespace UnboundedDiscOffset

/-- Witness-positivity: in the `‚ąÄ B, ‚ąÉ n, B < discOffset f d m n` unboundedness normal form,
any witness length `n` is automatically positive.

Reason: `discOffset f d m 0 = 0`, so `B < discOffset f d m 0` is impossible.
-/
theorem forall_exists_discOffset_gt_witness_pos {f : ‚Ąē ‚Üí ‚Ą§} {d m : ‚Ąē}
    (hunb : UnboundedDiscOffset f d m) :
    ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, n > 0 ‚ąß B < discOffset f d m n := by
  intro B
  rcases hunb B with ‚ü®n, hn‚ü©
  have hn0 : n ‚Č† 0 := by
    intro h0
    subst h0
    have : ¬¨ B < discOffset f d m 0 := by
      simp
    exact this hn
  exact ‚ü®n, Nat.pos_of_ne_zero hn0, hn‚ü©

/-- Witness-positivity: in the inequality-direction unboundedness normal form
`‚ąÄ B, ‚ąÉ n, discOffset f d m n > B`, any witness length `n` is automatically positive.

This is `forall_exists_discOffset_gt_witness_pos` rewritten using `gt_iff_lt`.
-/
theorem forall_exists_discOffset_gt'_witness_pos {f : ‚Ąē ‚Üí ‚Ą§} {d m : ‚Ąē}
    (hunb : UnboundedDiscOffset f d m) :
    ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, n > 0 ‚ąß discOffset f d m n > B := by
  intro B
  rcases forall_exists_discOffset_gt_witness_pos (f := f) (d := d) (m := m) hunb B with
    ‚ü®n, hnpos, hn‚ü©
  exact ‚ü®n, hnpos, (gt_iff_lt).2 hn‚ü©

/-- Witness-positivity: in the bundled-nucleus witness form
`‚ąÄ B, ‚ąÉ n, Int.natAbs (apSumOffset f d m n) > B`, any witness length `n` is automatically positive.

Reason: `apSumOffset f d m 0 = 0`.
-/
theorem forall_exists_natAbs_apSumOffset_gt_witness_pos {f : ‚Ąē ‚Üí ‚Ą§} {d m : ‚Ąē}
    (hunb : UnboundedDiscOffset f d m) :
    ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, n > 0 ‚ąß Int.natAbs (apSumOffset f d m n) > B := by
  intro B
  rcases forall_exists_discOffset_gt_witness_pos (f := f) (d := d) (m := m) hunb B with
    ‚ü®n, hnpos, hn‚ü©
  refine ‚ü®n, hnpos, ?_‚ü©
  have hn' : B < Int.natAbs (apSumOffset f d m n) := by
    have hn' := hn
    unfold discOffset at hn'
    exact hn'
  exact (gt_iff_lt).2 hn'

/-- Witness-positivity normal form: unbounded offset discrepancy is equivalent to arbitrarily large
bundled offset nuclei, with witnesses `n > 0`.

This is `unboundedDiscOffset_iff_forall_exists_discOffset_gt'_witness_pos` rewritten using the
definitional equality `discOffset = Int.natAbs (apSumOffset ...)`.
-/
theorem iff_forall_exists_natAbs_apSumOffset_gt'_witness_pos (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ
      (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, n > 0 ‚ąß Int.natAbs (apSumOffset f d m n) > B) := by
  constructor
  ¬∑ intro hunb B
    rcases
        (unboundedDiscOffset_iff_forall_exists_discOffset_gt'_witness_pos (f := f) (d := d) (m := m)).1
          hunb B with
      ‚ü®n, hnpos, hn‚ü©
    refine ‚ü®n, hnpos, ?_‚ü©
    have hn' := hn
    unfold discOffset at hn'
    exact hn'
  ¬∑ intro h
    refine
      (unboundedDiscOffset_iff_forall_exists_discOffset_gt'_witness_pos (f := f) (d := d) (m := m)).2
        ?_
    intro B
    rcases h B with ‚ü®n, hnpos, hn‚ü©
    refine ‚ü®n, hnpos, ?_‚ü©
    unfold discOffset
    exact hn

/-- Normal form: unbounded offset discrepancy expressed directly using the bundled offset nucleus.

Since `discOffset f d m n` is definitionally `Int.natAbs (apSumOffset f d m n)`, this lemma lets
later stages avoid unfolding `discOffset` by hand.
-/
theorem iff_forall_exists_natAbs_apSumOffset_gt (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ
      (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < Int.natAbs (apSumOffset f d m n)) := by
  simp [UnboundedDiscOffset, discOffset, -natAbs_apSumOffset_eq_discOffset]

/-- Variant of `iff_forall_exists_natAbs_apSumOffset_gt` with the inequality written as
`Int.natAbs ... > B` (often the normal form used by Stage interfaces).
-/
theorem iff_forall_exists_natAbs_apSumOffset_gt' (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ
      (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, Int.natAbs (apSumOffset f d m n) > B) := by
  simpa [gt_iff_lt] using (iff_forall_exists_natAbs_apSumOffset_gt (f := f) (d := d) (m := m))

/-- Normal form: unbounded offset discrepancy expressed using affine-tail nuclei
`apSumFrom f (m*d) d n`.

This is a lightweight rewrite of `iff_forall_exists_natAbs_apSumOffset_gt` using the identity
`apSumFrom f (m*d) d n = apSumOffset f d m n`.
-/
theorem iff_forall_exists_natAbs_apSumFrom_mul_gt (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ
      (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < Int.natAbs (apSumFrom f (m * d) d n)) := by
  constructor
  ¬∑ intro hunb B
    rcases (iff_forall_exists_natAbs_apSumOffset_gt (f := f) (d := d) (m := m)).1 hunb B with
      ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    have hsum : apSumOffset f d m n = apSumFrom f (m * d) d n := by
      simpa using (apSumFrom_mul_eq_apSumOffset (f := f) (d := d) (m := m) (n := n)).symm
    simpa [hsum] using hn
  ¬∑ intro h
    refine (iff_forall_exists_natAbs_apSumOffset_gt (f := f) (d := d) (m := m)).2 ?_
    intro B
    rcases h B with ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    have hsum : apSumOffset f d m n = apSumFrom f (m * d) d n := by
      simpa using (apSumFrom_mul_eq_apSumOffset (f := f) (d := d) (m := m) (n := n)).symm
    -- Rewrite the tail nucleus back to the bundled offset nucleus.
    simpa [hsum.symm] using hn

/-- Variant of `iff_forall_exists_natAbs_apSumFrom_mul_gt` with the inequality written as
`Int.natAbs ... > B`.
-/
theorem iff_forall_exists_natAbs_apSumFrom_mul_gt' (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ
      (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, Int.natAbs (apSumFrom f (m * d) d n) > B) := by
  simpa [gt_iff_lt] using
    (iff_forall_exists_natAbs_apSumFrom_mul_gt (f := f) (d := d) (m := m))

/-- Witness-positivity: in the tail-nucleus witness form
`‚ąÄ B, ‚ąÉ n, Int.natAbs (apSumFrom f (m*d) d n) > B`,
any witness length `n` is automatically positive.

Reason: `apSumFrom f (m*d) d 0 = 0`.
-/
theorem forall_exists_natAbs_apSumFrom_mul_gt_witness_pos {f : ‚Ąē ‚Üí ‚Ą§} {d m : ‚Ąē}
    (hunb : UnboundedDiscOffset f d m) :
    ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, n > 0 ‚ąß Int.natAbs (apSumFrom f (m * d) d n) > B := by
  intro B
  rcases (iff_forall_exists_natAbs_apSumFrom_mul_gt' (f := f) (d := d) (m := m)).1 hunb B with
    ‚ü®n, hn‚ü©
  have hn0 : n ‚Č† 0 := by
    intro h0
    subst h0
    have hzero : Int.natAbs (apSumFrom f (m * d) d 0) = 0 := by
      simp
    have hn0gt := hn
    rw [hzero] at hn0gt
    have hlt : B < 0 := (gt_iff_lt).1 hn0gt
    exact (Nat.not_lt_zero B) hlt
  exact ‚ü®n, Nat.pos_of_ne_zero hn0, hn‚ü©

/-- Negation-normal form: unbounded offset discrepancy means there is no uniform bound on the
affine-tail nuclei `Int.natAbs (apSumFrom f (m*d) d n)`.

This is the tail-nucleus analogue of `iff_not_exists_forall_natAbs_apSumOffset_le`.
-/
theorem iff_not_exists_forall_natAbs_apSumFrom_mul_le (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ
      (¬¨ ‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, Int.natAbs (apSumFrom f (m * d) d n) ‚Č§ B) := by
  classical
  constructor
  ¬∑ intro hunb h
    rcases h with ‚ü®B, hB‚ü©
    rcases (iff_forall_exists_natAbs_apSumFrom_mul_gt' (f := f) (d := d) (m := m)).1 hunb B with
      ‚ü®n, hn‚ü©
    exact (not_lt_of_ge (hB n)) hn
  ¬∑ intro hnb
    refine (iff_forall_exists_natAbs_apSumFrom_mul_gt' (f := f) (d := d) (m := m)).2 ?_
    intro B
    by_contra h
    have hB : ‚ąÄ n : ‚Ąē, Int.natAbs (apSumFrom f (m * d) d n) ‚Č§ B := by
      intro n
      exact le_of_not_gt (by
        intro hgt
        exact h ‚ü®n, hgt‚ü©)
    exact hnb ‚ü®B, hB‚ü©

/-- Negation-normal form: unbounded offset discrepancy means there is no uniform bound on the
bundled offset nuclei `Int.natAbs (apSumOffset f d m n)`.

This is often the most convenient form for proofs by contradiction.
-/
theorem iff_not_exists_forall_natAbs_apSumOffset_le (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ
      (¬¨ ‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, Int.natAbs (apSumOffset f d m n) ‚Č§ B) := by
  classical
  constructor
  ¬∑ intro hunb h
    rcases h with ‚ü®B, hB‚ü©
    rcases hunb B with ‚ü®n, hn‚ü©
    have hn' : B < Int.natAbs (apSumOffset f d m n) := by
      -- Avoid simp loops: `discOffset` is definitional.
      have hn' := hn
      unfold discOffset at hn'
      exact hn'
    exact (not_lt_of_ge (hB n)) hn'
  ¬∑ intro hnb B
    by_contra h
    -- If there is no witness beating B, then B is a uniform bound.
    have hB : ‚ąÄ n : ‚Ąē, Int.natAbs (apSumOffset f d m n) ‚Č§ B := by
      intro n
      have hnot : ¬¨ B < discOffset f d m n := by
        intro hlt
        exact h ‚ü®n, hlt‚ü©
      have hle : discOffset f d m n ‚Č§ B := by
        exact le_of_not_gt (by
          intro hgt
          exact hnot (by simpa [gt_iff_lt] using hgt))
      -- Avoid simp loops: `discOffset` is definitional.
      have hle' := hle
      unfold discOffset at hle'
      exact hle'
    exact hnb ‚ü®B, hB‚ü©

/-- Paper-notation normal form: unbounded offset discrepancy means there is no uniform bound on the
shifted progression sums
`‚ąĎ i ‚ąą Icc (m+1) (m+n), f (i*d)`.

Negation-normal form:
`¬¨ ‚ąÉ B, ‚ąÄ n, Int.natAbs ((Icc (m+1) (m+n)).sum (fun i => f (i*d))) ‚Č§ B`.

This is `iff_not_exists_forall_natAbs_apSumOffset_le` rewritten using
`natAbs_apSumOffset_eq_natAbs_sum_Icc`.
-/
theorem iff_not_exists_forall_natAbs_sum_Icc_offset_le (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ
      (¬¨ ‚ąÉ B : ‚Ąē,
        ‚ąÄ n : ‚Ąē,
          Int.natAbs ((Finset.Icc (m + 1) (m + n)).sum (fun i => f (i * d))) ‚Č§ B) := by
  have hiff :
      (‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, Int.natAbs (apSumOffset f d m n) ‚Č§ B) ‚ÜĒ
        (‚ąÉ B : ‚Ąē,
          ‚ąÄ n : ‚Ąē,
            Int.natAbs ((Finset.Icc (m + 1) (m + n)).sum (fun i => f (i * d))) ‚Č§ B) := by
    constructor
    ¬∑ rintro ‚ü®B, hB‚ü©
      refine ‚ü®B, ?_‚ü©
      intro n
      simpa [natAbs_apSumOffset_eq_natAbs_sum_Icc (f := f) (d := d) (m := m) (n := n)] using hB n
    ¬∑ rintro ‚ü®B, hB‚ü©
      refine ‚ü®B, ?_‚ü©
      intro n
      simpa [natAbs_apSumOffset_eq_natAbs_sum_Icc (f := f) (d := d) (m := m) (n := n)] using hB n

  exact
    (iff_not_exists_forall_natAbs_apSumOffset_le (f := f) (d := d) (m := m)).trans
      (not_congr hiff)

end UnboundedDiscOffset

/-- Normal form: unbounded offset discrepancy means there is no uniform bundled offset-nucleus bound.

Negation-normal form:
`¬¨ ‚ąÉ B, ‚ąÄ n, Int.natAbs (apSumOffset f d m n) ‚Č§ B`.

This is just a naming wrapper around
`UnboundedDiscOffset.iff_not_exists_forall_natAbs_apSumOffset_le`.
-/
theorem unboundedDiscOffset_iff_not_exists_forall_natAbs_apSumOffset_le (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ (¬¨ ‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, Int.natAbs (apSumOffset f d m n) ‚Č§ B) := by
  simpa using
    (UnboundedDiscOffset.iff_not_exists_forall_natAbs_apSumOffset_le (f := f) (d := d) (m := m))

/-- Normal form: unbounded offset discrepancy means there is no uniform `discOffset` bound.

Negation-normal form:
`¬¨ ‚ąÉ B, ‚ąÄ n, discOffset f d m n ‚Č§ B`.

This is the definitional `discOffset` rewrite of
`UnboundedDiscOffset.iff_not_exists_forall_natAbs_apSumOffset_le`.
-/
theorem unboundedDiscOffset_iff_not_exists_forall_discOffset_le (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ (¬¨ ‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, discOffset f d m n ‚Č§ B) := by
  -- Avoid simp loops: `discOffset` is definitional.
  simpa [discOffset, -natAbs_apSumOffset_eq_discOffset] using
    (UnboundedDiscOffset.iff_not_exists_forall_natAbs_apSumOffset_le (f := f) (d := d) (m := m))

/-- Preferred naming for the core lemma
`MoltResearch.not_exists_boundedDiscOffset_iff_forall_exists_discOffset_lt`.

The witnesses have the form `B < discOffset ...`, so we use the suffix `_gt` (‚Äúgreater than B‚ÄĚ).
-/
theorem not_exists_boundedDiscOffset_iff_forall_exists_discOffset_gt (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    (¬¨ ‚ąÉ B : ‚Ąē, BoundedDiscOffset f d m B) ‚ÜĒ ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < discOffset f d m n := by
  simpa using
    (MoltResearch.not_exists_boundedDiscOffset_iff_forall_exists_discOffset_lt (f := f) (d := d)
      (m := m))

/-- Inequality-direction variant of `not_exists_boundedDiscOffset_iff_forall_exists_discOffset_gt`,
written as `discOffset ... > B`.

Many consumers prefer this normal form so they can `simp [gt_iff_lt]` at the call site.
-/
theorem not_exists_boundedDiscOffset_iff_forall_exists_discOffset_gt' (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    (¬¨ ‚ąÉ B : ‚Ąē, BoundedDiscOffset f d m B) ‚ÜĒ (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, discOffset f d m n > B) := by
  simpa [gt_iff_lt] using
    (not_exists_boundedDiscOffset_iff_forall_exists_discOffset_gt (f := f) (d := d) (m := m))

/-- Bridge: the witness form `UnboundedDiscOffset` is equivalent to the negation-normal-form boundedness
statement `¬¨ ‚ąÉ B, BoundedDiscOffset f d m B`.

This lets later stages switch to a stable boundedness predicate without unfolding `discOffset`.
-/
theorem unboundedDiscOffset_iff_not_exists_boundedDiscOffset (f : ‚Ąē ‚Üí ‚Ą§) (d m : ‚Ąē) :
    UnboundedDiscOffset f d m ‚ÜĒ ¬¨ ‚ąÉ B : ‚Ąē, BoundedDiscOffset f d m B := by
  simpa [UnboundedDiscOffset] using
    (not_exists_boundedDiscOffset_iff_forall_exists_discOffset_gt (f := f) (d := d) (m := m)).symm

/-- Monotonicity: a `discOffset` bound can be weakened to any larger bound. -/
theorem boundedDiscOffset_mono {f : ‚Ąē ‚Üí ‚Ą§} {d m B B' : ‚Ąē}
    (h : BoundedDiscOffset f d m B) (hBB' : B ‚Č§ B') : BoundedDiscOffset f d m B' := by
  intro n
  exact le_trans (h n) hBB'

/-!
### Bridges to the verified along-`d` predicates in `MoltResearch.Discrepancy`

Track C uses bespoke stage-record interfaces under `MoltResearch.Tao2015`, but it is convenient
to interoperate with the verified Track B ‚Äúalong-`d`‚ÄĚ normal forms.
-/

/-- Bridge: Track C `HasDiscrepancyAtLeastAlong` agrees with the core predicate
`MoltResearch.HasDiscrepancyAtLeastAlong`. -/
theorem hasDiscrepancyAtLeastAlong_iff_core (g : ‚Ąē ‚Üí ‚Ą§) (d C : ‚Ąē) :
    HasDiscrepancyAtLeastAlong g d C ‚ÜĒ MoltResearch.HasDiscrepancyAtLeastAlong g d C := by
  unfold HasDiscrepancyAtLeastAlong MoltResearch.HasDiscrepancyAtLeastAlong
  constructor <;> rintro ‚ü®n, hn‚ü© <;> refine ‚ü®n, ?_‚ü© <;> simpa [gt_iff_lt] using hn

/-- Bridge: Track C `UnboundedDiscrepancyAlong` agrees with the core predicate
`MoltResearch.UnboundedDiscrepancyAlong`. -/
theorem unboundedDiscrepancyAlong_iff_core (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    UnboundedDiscrepancyAlong g d ‚ÜĒ MoltResearch.UnboundedDiscrepancyAlong g d := by
  unfold UnboundedDiscrepancyAlong MoltResearch.UnboundedDiscrepancyAlong MoltResearch.HasDiscrepancyAtLeastAlong
  constructor
  ¬∑ intro hunb C
    rcases hunb C with ‚ü®n, hn‚ü©
    exact ‚ü®n, by simpa [gt_iff_lt] using hn‚ü©
  ¬∑ intro hunb B
    rcases hunb B with ‚ü®n, hn‚ü©
    exact ‚ü®n, by simpa [gt_iff_lt] using hn‚ü©

namespace UnboundedDiscrepancyAlong

/-- Classical equivalence: unboundedness along `d` is the negation of boundedness along `d`.

This is just `Tao2015.unboundedDiscrepancyAlong_iff_not_boundedDiscrepancyAlong`, restated in the
namespaced form `UnboundedDiscrepancyAlong.iff_not_boundedDiscrepancyAlong`.
-/
theorem iff_not_boundedDiscrepancyAlong (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    UnboundedDiscrepancyAlong g d ‚ÜĒ ¬¨ BoundedDiscrepancyAlong g d := by
  simpa using (Tao2015.unboundedDiscrepancyAlong_iff_not_boundedDiscrepancyAlong (g := g) (d := d))

/-- Nucleus normal form: unboundedness along `d` means there is no uniform bound on
`Int.natAbs (apSum g d n)`.

This is `iff_not_boundedDiscrepancyAlong` composed with
`boundedDiscrepancyAlong_iff_exists_forall_natAbs_apSum_le`.
-/
theorem iff_not_exists_forall_natAbs_apSum_le (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    UnboundedDiscrepancyAlong g d ‚ÜĒ ¬¨ ‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, Int.natAbs (apSum g d n) ‚Č§ B := by
  simpa using
    (iff_not_boundedDiscrepancyAlong (g := g) (d := d)).trans
      (not_congr (boundedDiscrepancyAlong_iff_exists_forall_natAbs_apSum_le (g := g) (d := d)))

end UnboundedDiscrepancyAlong

namespace HasDiscrepancyAtLeastAlong

/-- `‚ąÄ C, HasDiscrepancyAtLeastAlong g d C` is just `UnboundedDiscrepancyAlong g d`. -/
theorem forall_hasDiscrepancyAtLeastAlong_iff_unboundedDiscrepancyAlong (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) :
    (‚ąÄ C : ‚Ąē, HasDiscrepancyAtLeastAlong g d C) ‚ÜĒ UnboundedDiscrepancyAlong g d := by
  constructor
  ¬∑ intro h B
    exact h B
  ¬∑ intro hunb C
    exact hunb C

/-- Witness-positivity: any witness for `HasDiscrepancyAtLeastAlong g d C` must have `n > 0`,
since `discrepancy g d 0 = 0`.

This is a tiny convenience lemma used by later stages to avoid splitting on the `n = 0` case.
-/
theorem exists_witness_pos {g : ‚Ąē ‚Üí ‚Ą§} {d C : ‚Ąē} (h : HasDiscrepancyAtLeastAlong g d C) :
    ‚ąÉ n : ‚Ąē, n > 0 ‚ąß C < discrepancy g d n := by
  rcases h with ‚ü®n, hn‚ü©
  have hn0 : n ‚Č† 0 := by
    intro h0
    subst h0
    simp [discrepancy_zero] at hn
  exact ‚ü®n, Nat.pos_of_ne_zero hn0, hn‚ü©

end HasDiscrepancyAtLeastAlong

/-!
## Global contexts (boundedness data)

These are small records bundling bounds in a consumer-friendly way.
They are intentionally *weak*: later stages can strengthen/replace them.
-/

/-- A global boundedness context for `f`, extracted from `BoundedDiscrepancy f`. -/
structure Context (f : ‚Ąē ‚Üí ‚Ą§) : Type where
  /-- A global bound. -/
  B : ‚Ąē
  /-- Bound on homogeneous discrepancy (`discrepancy = natAbs(apSum)`). -/
  bound_discrepancy : ‚ąÄ d n : ‚Ąē, d > 0 ‚Üí discrepancy f d n ‚Č§ B
  /-- A convenient derived bound for offset discrepancy families. -/
  bound_discOffset_two_mul : ‚ąÄ d m n : ‚Ąē, d > 0 ‚Üí discOffset f d m n ‚Č§ 2 * B

namespace Context

/-- Build a `Context` from `BoundedDiscrepancy`.

Note: `BoundedDiscrepancy f` lives in `Prop`, while `Context f` is a `Type`, so we must use
classical choice rather than pattern matching on the existential witness.
-/
noncomputable def ofBoundedDiscrepancy (f : ‚Ąē ‚Üí ‚Ą§) (hb : BoundedDiscrepancy f) : Context f := by
  classical
  let B : ‚Ąē := Classical.choose hb
  have hB : ‚ąÄ d n : ‚Ąē, d > 0 ‚Üí Int.natAbs (apSum f d n) ‚Č§ B := Classical.choose_spec hb
  refine
    { B := B
      bound_discrepancy := ?_
      bound_discOffset_two_mul := ?_ }
  ¬∑ intro d n hd
    -- `discrepancy` is definitionally `Int.natAbs (apSum ...)`.
    change Int.natAbs (apSum f d n) ‚Č§ B
    exact hB d n hd
  ¬∑ intro d m n hd
    -- Offset sum is a difference of two prefix sums; use triangle inequality + the global bound.
    have hEq : apSum f d (m + n) + (- apSum f d m) = apSumOffset f d m n := by
      calc
        apSum f d (m + n) + (- apSum f d m)
            = apSum f d (m + n) - apSum f d m := by
                simp [sub_eq_add_neg]
        _ = apSumOffset f d m n :=
          (MoltResearch.apSumOffset_eq_sub (f := f) (d := d) (m := m) (n := n)).symm

    have htri :
        Int.natAbs (apSumOffset f d m n) ‚Č§
          Int.natAbs (apSum f d (m + n)) + Int.natAbs (apSum f d m) := by
      simpa [hEq, Int.natAbs_neg] using
        (Int.natAbs_add_le (apSum f d (m + n)) (- apSum f d m))

    have hsum :
        Int.natAbs (apSum f d (m + n)) + Int.natAbs (apSum f d m) ‚Č§ B + B :=
      Nat.add_le_add (hB d (m + n) hd) (hB d m hd)

    have hfinal : Int.natAbs (apSumOffset f d m n) ‚Č§ B + B :=
      le_trans htri hsum

    have : discOffset f d m n ‚Č§ B + B := by
      change Int.natAbs (apSumOffset f d m n) ‚Č§ B + B
      exact hfinal

    simpa [two_mul] using this

/-- Convenience normal form: the global `discOffset` bound bundled in `Context` is equivalently a
bound on the bundled offset nucleus `Int.natAbs (apSumOffset ...)`.

This prevents consumers from having to unfold `discOffset` at each call site.
-/
theorem bound_natAbs_apSumOffset_two_mul {f : ‚Ąē ‚Üí ‚Ą§} (ctx : Context f) (d m n : ‚Ąē) (hd : d > 0) :
    Int.natAbs (apSumOffset f d m n) ‚Č§ 2 * ctx.B := by
  -- `discOffset` is definitionally `Int.natAbs (apSumOffset ...)`, so this is exactly the stored bound.
  exact ctx.bound_discOffset_two_mul (d := d) (m := m) (n := n) hd

/-- Package the stored `discOffset` bound as a `BoundedDiscOffset` witness. -/
theorem boundedDiscOffset_two_mul {f : ‚Ąē ‚Üí ‚Ą§} (ctx : Context f) (d m : ‚Ąē) (hd : d > 0) :
    BoundedDiscOffset f d m (2 * ctx.B) := by
  intro n
  simpa using ctx.bound_discOffset_two_mul (d := d) (m := m) (n := n) hd

end Context

/-- Fixed-step analogue of `Context`: a bound on `discrepancy g d n` for all `n`. -/
structure ContextAlong (g : ‚Ąē ‚Üí ‚Ą§) (d : ‚Ąē) : Type where
  B : ‚Ąē
  bound_discrepancy : ‚ąÄ n : ‚Ąē, discrepancy g d n ‚Č§ B

namespace ContextAlong

/-- Build a `ContextAlong` from `BoundedDiscrepancyAlong`.

As with `Context.ofBoundedDiscrepancy`, we use classical choice to extract the witness.
-/
noncomputable def ofBoundedDiscrepancyAlong {g : ‚Ąē ‚Üí ‚Ą§} {d : ‚Ąē} (hb : BoundedDiscrepancyAlong g d) :
    ContextAlong g d := by
  classical
  let B : ‚Ąē := Classical.choose hb
  have hB : ‚ąÄ n : ‚Ąē, discrepancy g d n ‚Č§ B := Classical.choose_spec hb
  exact ‚ü®B, hB‚ü©

/-- Turn a `ContextAlong` back into `BoundedDiscrepancyAlong`. -/
theorem toBoundedDiscrepancyAlong {g : ‚Ąē ‚Üí ‚Ą§} {d : ‚Ąē} (ctx : ContextAlong g d) :
    BoundedDiscrepancyAlong g d := by
  exact ‚ü®ctx.B, ctx.bound_discrepancy‚ü©

/-- Normal form: the discrepancy bound stored in `ContextAlong` is equivalently a bound on the
fixed-step nucleus `Int.natAbs (apSum g d n)`.

This prevents consumers from having to unfold `discrepancy` at each call site.
-/
theorem bound_natAbs_apSum {g : ‚Ąē ‚Üí ‚Ą§} {d : ‚Ąē} (ctx : ContextAlong g d) (n : ‚Ąē) :
    Int.natAbs (apSum g d n) ‚Č§ ctx.B := by
  -- `discrepancy g d n` is definitionally `Int.natAbs (apSum g d n)`.
  change discrepancy g d n ‚Č§ ctx.B
  exact ctx.bound_discrepancy n

end ContextAlong

/-- If some offset discrepancy family is unbounded, then `f` cannot have globally bounded discrepancy.

This is the global (non‚ÄďStage-1-specific) contrapositive used by later stages: global bounded
discrepancy implies a uniform bound on every `discOffset f d m`, so unboundedness of any one such
family yields a contradiction.
-/
theorem not_boundedDiscrepancy_of_forall_exists_discOffset_gt (f : ‚Ąē ‚Üí ‚Ą§) {d m : ‚Ąē} (hd : d > 0)
    (hunb : ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < discOffset f d m n) :
    ¬¨ BoundedDiscrepancy f := by
  intro hb
  -- Turn global boundedness into a reusable `Context`, then contradict the unbounded witness.
  let ctx : Context f := Context.ofBoundedDiscrepancy (f := f) hb
  have hbound : ‚ąÄ n : ‚Ąē, discOffset f d m n ‚Č§ 2 * ctx.B := by
    intro n
    simpa using (ctx.bound_discOffset_two_mul (f := f) (d := d) (m := m) (n := n) hd)
  rcases hunb (2 * ctx.B) with ‚ü®n, hn‚ü©
  exact (not_lt_of_ge (hbound n)) hn

/-- Variant of `not_boundedDiscrepancy_of_forall_exists_discOffset_gt` with the witness inequality
written as `discOffset ... > B`.

Many consumers prefer this normal form so they can `simp [gt_iff_lt]` at the call site.
-/
theorem not_boundedDiscrepancy_of_forall_exists_discOffset_gt' (f : ‚Ąē ‚Üí ‚Ą§) {d m : ‚Ąē} (hd : d > 0)
    (hunb : ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, discOffset f d m n > B) :
    ¬¨ BoundedDiscrepancy f := by
  refine not_boundedDiscrepancy_of_forall_exists_discOffset_gt (f := f) (d := d) (m := m) hd ?_
  intro B
  rcases hunb B with ‚ü®n, hn‚ü©
  exact ‚ü®n, (gt_iff_lt).1 hn‚ü©

/-!
## Stage 1: shift reduction output

Stage 1 packages a derived sign sequence `g` (typically a shift of `f`), together with a fixed
step size `d` and an offset parameter `m`, plus *transport contracts* between discrepancy
statements about `g` and offset discrepancy statements about `f`.

This is deliberately an IO-style record: downstream stages should consume the record rather than
re-proving ad-hoc rewrites.
-/

structure ReductionOutput (f : ‚Ąē ‚Üí ‚Ą§) : Type where
  /-- Fixed step size for the reduced locus. -/
  d : ‚Ąē
  /-- The step size is positive.

  Most discrepancy statements (including `BoundedDiscrepancy`) only quantify over `d > 0`.
  We store this here so later stages can use it without threading it separately.
  -/
  hd : d > 0
  /-- Offset parameter bundling the tail `m*d`. -/
  m : ‚Ąē
  /-- Reduced sign sequence. -/
  g : ‚Ąē ‚Üí ‚Ą§
  /-- Proof that `g` is a sign sequence. -/
  hg : IsSignSequence g
  /-- Defining equation: `g k = f (k + m*d)`.

  We keep this explicit because it is frequently used for rewriting.
  -/
  g_eq : ‚ąÄ k : ‚Ąē, g k = f (k + m * d)
  /-- Transfer contract: a uniform bound on `discOffset f d m` bounds `discrepancy g d`. -/
  contract_discrepancy_le :
    ‚ąÄ B : ‚Ąē, (‚ąÄ n : ‚Ąē, discOffset f d m n ‚Č§ B) ‚Üí ‚ąÄ n : ‚Ąē, discrepancy g d n ‚Č§ B

namespace ReductionOutput

variable {f : ‚Ąē ‚Üí ‚Ą§}

/-- Canonical Stage-1 reduction: shift `f` by `m*d`.

This is the ‚Äúpure index gymnastics‚ÄĚ step: it defines
`g k := f (k + m*d)`.

The transport contract `contract_discrepancy_le` is discharged by rewriting
`discrepancy (fun k => f (k + m*d)) d` into the bundled offset form `discOffset f d m`.
-/
def ofShift (f : ‚Ąē ‚Üí ‚Ą§) (hf : IsSignSequence f) (d m : ‚Ąē) (hd : d > 0) : ReductionOutput f := by
  classical
  refine
    { d := d
      hd := hd
      m := m
      g := fun k => f (k + m * d)
      hg := ?_
      g_eq := ?_
      contract_discrepancy_le := ?_ }
  ¬∑ intro k
    simpa using hf (k + m * d)
  ¬∑ intro k
    rfl
  ¬∑ intro B hB n
    -- Normalize the reduced discrepancy to the bundled offset discrepancy wrapper.
    have hrewrite :
        discrepancy (fun k => f (k + m * d)) d n = discOffset f d m n := by
      -- `discrepancy_shift_mul_simp` is the standard normal form for shifts by `m*d`.
      exact discrepancy_shift_mul_simp (f := f) (m := m) (d := d) (n := n)
    -- Now discharge the bound using the supplied uniform `discOffset` bound.
    simpa [hrewrite] using hB n

/-- Stage-1 reduction combinator: shift the reduced sequence again by `m‚āā * out.d`.

This is the first ‚Äúactually used‚ÄĚ reduction composition operator downstream stages need:
Tao‚Äôs pipeline frequently produces a reduced locus and then shifts it again.

- It keeps the step size `d` unchanged.
- It updates the offset parameter from `m` to `m + m‚āā`.
- It defines the new reduced sequence as `k ‚Ü¶ out.g (k + m‚āā*out.d)`.

The key point: this constructor does **not** require any global sign-sequence hypothesis for `f`;
we reuse `out.hg` and `out.g_eq`.
-/
def shiftRight (out : ReductionOutput f) (m‚āā : ‚Ąē) : ReductionOutput f := by
  classical
  let m' : ‚Ąē := out.m + m‚āā
  refine
    { d := out.d
      hd := out.hd
      m := m'
      g := fun k => out.g (k + m‚āā * out.d)
      hg := ?_
      g_eq := ?_
      contract_discrepancy_le := ?_ }
  ¬∑ intro k
    -- `out.g` is a sign sequence, so any shift of it is also a sign sequence.
    exact out.hg (k + m‚āā * out.d)
  ¬∑ intro k
    -- Expand `out.g` using `out.g_eq` and normalize the index arithmetic.
    calc
      out.g (k + m‚āā * out.d) = f ((k + m‚āā * out.d) + out.m * out.d) := by
        simp [out.g_eq]
      _ = f (k + (out.m + m‚āā) * out.d) := by
        -- Pure `Nat` semiring arithmetic.
        simp [Nat.add_assoc, Nat.add_comm, Nat.mul_comm, Nat.mul_add]
  ¬∑ intro B hB n
    -- Rewrite `g` to the canonical shift of `f` so we can reuse `discrepancy_shift_mul_simp`.
    have hgfun : (fun k => out.g (k + m‚āā * out.d)) = fun k => f (k + m' * out.d) := by
      funext k
      -- Use the defining equation we just provided.
      simpa [m', Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using (show
        out.g (k + m‚āā * out.d) = f (k + (out.m + m‚āā) * out.d) from (by
          -- same calc as above
          calc
            out.g (k + m‚āā * out.d) = f ((k + m‚āā * out.d) + out.m * out.d) := by
              simp [out.g_eq]
            _ = f (k + (out.m + m‚āā) * out.d) := by
              simp [Nat.add_assoc, Nat.add_comm, Nat.mul_comm, Nat.mul_add]))

    have hrewrite :
        discrepancy (fun k => f (k + m' * out.d)) out.d n = discOffset f out.d m' n := by
      exact discrepancy_shift_mul_simp (f := f) (m := m') (d := out.d) (n := n)

    -- Discharge the bound.
    simpa [hgfun, hrewrite] using hB n

/-! ### `shiftRight` coherence lemmas

We intentionally keep this file minimal; if/when downstream stages need simp-normalization lemmas
like `shiftRight_zero` or associativity, add them together with small regression examples.
-/

/-- Coherence: the offset parameter of `out.shiftRight m‚āā` is `out.m + m‚āā`.

This is a tiny simp-normalization lemma: it avoids having to unfold `shiftRight` at each call site.
-/
@[simp] theorem shiftRight_m (out : ReductionOutput f) (m‚āā : ‚Ąē) :
    (out.shiftRight m‚āā).m = out.m + m‚āā := by
  simp [ReductionOutput.shiftRight]

/-- Consumer-facing rewrite: discrepancy of the reduced sequence equals bundled offset discrepancy.

This is the key normal-form bridge used by later stages.
-/
theorem discrepancy_eq_discOffset_via_contract (out : ReductionOutput f) (n : ‚Ąē) :
    discrepancy out.g out.d n = discOffset f out.d out.m n := by
  -- `out.g_eq` identifies `out.g` with the canonical shift `fun k ‚Ü¶ f (k + m*d)`.
  have hgfun : out.g = fun k => f (k + out.m * out.d) := by
    funext k
    simp [out.g_eq]
  -- Now normalize discrepancy of a shift by `m*d`.
  simp [hgfun, discrepancy_shift_mul_simp (f := f) (m := out.m) (d := out.d) (n := n)]

/-- Consumer-facing rewrite: the stable wrapper `discAlong` for the reduced sequence equals the
bundled offset discrepancy wrapper for the original sequence.

This is a tiny packaging lemma around `discrepancy_eq_discOffset_via_contract`.
-/
theorem discAlong_eq_discOffset (out : ReductionOutput f) (n : ‚Ąē) :
    discAlong out.g out.d n = discOffset f out.d out.m n := by
  simpa [discAlong_eq_discrepancy] using
    out.discrepancy_eq_discOffset_via_contract (f := f) (n := n)

/-- Convenience: pointwise discrepancy bounds for the reduced sequence are exactly pointwise bounds
on the bundled offset family. -/
theorem discrepancy_le_iff_discOffset_le (out : ReductionOutput f) (n B : ‚Ąē) :
    discrepancy out.g out.d n ‚Č§ B ‚ÜĒ discOffset f out.d out.m n ‚Č§ B := by
  simp [out.discrepancy_eq_discOffset_via_contract (f := f) (n := n)]

/-- Convenience: pointwise strict-inequality witnesses for the reduced sequence are exactly
pointwise witnesses for the bundled offset family. -/
theorem lt_discrepancy_iff_lt_discOffset (out : ReductionOutput f) (n B : ‚Ąē) :
    B < discrepancy out.g out.d n ‚ÜĒ B < discOffset f out.d out.m n := by
  simp [out.discrepancy_eq_discOffset_via_contract (f := f) (n := n)]

/-- Convenience: uniform discrepancy bounds for the reduced sequence are exactly uniform bounds on
the bundled offset family. -/
theorem forall_discrepancy_le_iff_forall_discOffset_le (out : ReductionOutput f) (B : ‚Ąē) :
    (‚ąÄ n : ‚Ąē, discrepancy out.g out.d n ‚Č§ B) ‚ÜĒ (‚ąÄ n : ‚Ąē, discOffset f out.d out.m n ‚Č§ B) := by
  constructor
  ¬∑ intro h n
    exact (out.discrepancy_le_iff_discOffset_le (f := f) (n := n) (B := B)).1 (h n)
  ¬∑ intro h n
    exact (out.discrepancy_le_iff_discOffset_le (f := f) (n := n) (B := B)).2 (h n)

/-- Bounded discrepancy along the reduced step is equivalent to a uniform bound on the bundled offset
discrepancy family.

This is a tiny packaging lemma: it lets consumers switch between the fixed-step normal form
(`discrepancy out.g out.d`) and the bundled offset normal form (`discOffset f out.d out.m`).
-/
theorem boundedDiscrepancyAlong_iff_exists_forall_discOffset_le (out : ReductionOutput f) :
    BoundedDiscrepancyAlong out.g out.d ‚ÜĒ
      ‚ąÉ B : ‚Ąē, ‚ąÄ n : ‚Ąē, discOffset f out.d out.m n ‚Č§ B := by
  unfold BoundedDiscrepancyAlong
  constructor
  ¬∑ rintro ‚ü®B, hB‚ü©
    refine ‚ü®B, (out.forall_discrepancy_le_iff_forall_discOffset_le (f := f) B).1 hB‚ü©
  ¬∑ rintro ‚ü®B, hB‚ü©
    refine ‚ü®B, (out.forall_discrepancy_le_iff_forall_discOffset_le (f := f) B).2 hB‚ü©

/-- Packaged form of `boundedDiscrepancyAlong_iff_exists_forall_discOffset_le` using the verified
predicate `BoundedDiscOffset`.

This keeps downstream code from having to remember the exact quantifier normal form of
`BoundedDiscOffset`.
-/
theorem boundedDiscrepancyAlong_iff_exists_boundedDiscOffset (out : ReductionOutput f) :
    BoundedDiscrepancyAlong out.g out.d ‚ÜĒ ‚ąÉ B : ‚Ąē, BoundedDiscOffset f out.d out.m B := by
  simpa [BoundedDiscOffset] using out.boundedDiscrepancyAlong_iff_exists_forall_discOffset_le (f := f)

/-- Stage-1 witness transport: reduced discrepancy-at-least is an affine-tail witness for `f`.

The affine nucleus is `apSumFrom f (m*d) d n`.
-/
theorem hasDiscrepancyAtLeastAlong_iff_exists_natAbs_apSumFrom_mul_gt (out : ReductionOutput f)
    (C : ‚Ąē) :
    HasDiscrepancyAtLeastAlong out.g out.d C ‚ÜĒ
      ‚ąÉ n : ‚Ąē, Int.natAbs (apSumFrom f (out.m * out.d) out.d n) > C := by
  unfold HasDiscrepancyAtLeastAlong
  constructor
  ¬∑ rintro ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    have hn' : C < discOffset f out.d out.m n := by
      simpa [discrepancy_eq_discOffset_via_contract (f := f) (out := out) (n := n)] using hn
    have hnOffset : C < Int.natAbs (apSumOffset f out.d out.m n) := by
      have hnOffset := hn'
      unfold discOffset at hnOffset
      exact hnOffset
    have hsum : apSumFrom f (out.m * out.d) out.d n = apSumOffset f out.d out.m n := by
      simpa using (apSumFrom_mul_eq_apSumOffset (f := f) (d := out.d) (m := out.m) (n := n))
    have hnFrom : C < Int.natAbs (apSumFrom f (out.m * out.d) out.d n) := by
      simpa [hsum] using hnOffset
    simpa [gt_iff_lt] using hnFrom

  ¬∑ rintro ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    have hnFrom : C < Int.natAbs (apSumFrom f (out.m * out.d) out.d n) := by
      simpa [gt_iff_lt] using hn
    have hsum : apSumFrom f (out.m * out.d) out.d n = apSumOffset f out.d out.m n := by
      simpa using (apSumFrom_mul_eq_apSumOffset (f := f) (d := out.d) (m := out.m) (n := n))
    have hnOffset : C < Int.natAbs (apSumOffset f out.d out.m n) := by
      simpa [hsum] using hnFrom
    have hnDiscOffset : C < discOffset f out.d out.m n := by
      change C < Int.natAbs (apSumOffset f out.d out.m n)
      exact hnOffset
    simpa [discrepancy_eq_discOffset_via_contract (f := f) (out := out) (n := n)] using hnDiscOffset

/-- Stage-1 transport: unbounded fixed-step discrepancy for the reduced sequence is equivalent to
arbitrarily large affine-tail witnesses for `f`.

This is the `‚ąÄ C` version of `hasDiscrepancyAtLeastAlong_iff_exists_natAbs_apSumFrom_mul_gt`.
-/
theorem unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumFrom_mul_gt (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d ‚ÜĒ
      ‚ąÄ C : ‚Ąē, ‚ąÉ n : ‚Ąē, Int.natAbs (apSumFrom f (out.m * out.d) out.d n) > C := by
  constructor
  ¬∑ intro hunb C
    exact
      (out.hasDiscrepancyAtLeastAlong_iff_exists_natAbs_apSumFrom_mul_gt (f := f) (C := C)).1
        (hunb C)
  ¬∑ intro h B
    exact
      (out.hasDiscrepancyAtLeastAlong_iff_exists_natAbs_apSumFrom_mul_gt (f := f) (C := B)).2
        (h B)

/-- Stage-1 transport: the family statement `‚ąÄ C, HasDiscrepancyAtLeastAlong out.g out.d C`
is equivalent to explicit affine-tail nucleus witnesses for `f`.

This is a convenience wrapper combining
`HasDiscrepancyAtLeastAlong.forall_hasDiscrepancyAtLeastAlong_iff_unboundedDiscrepancyAlong`
with `unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumFrom_mul_gt`.
-/
theorem forall_hasDiscrepancyAtLeastAlong_iff_forall_exists_natAbs_apSumFrom_mul_gt
    (out : ReductionOutput f) :
    (‚ąÄ C : ‚Ąē, HasDiscrepancyAtLeastAlong out.g out.d C) ‚ÜĒ
      (‚ąÄ C : ‚Ąē, ‚ąÉ n : ‚Ąē, Int.natAbs (apSumFrom f (out.m * out.d) out.d n) > C) := by
  constructor
  ¬∑ intro h
    have hunb : UnboundedDiscrepancyAlong out.g out.d :=
      (HasDiscrepancyAtLeastAlong.forall_hasDiscrepancyAtLeastAlong_iff_unboundedDiscrepancyAlong
        (g := out.g) (d := out.d)).1 h
    exact
      (out.unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumFrom_mul_gt (f := f)).1 hunb
  ¬∑ intro h
    have hunb : UnboundedDiscrepancyAlong out.g out.d :=
      (out.unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumFrom_mul_gt (f := f)).2 h
    exact
      (HasDiscrepancyAtLeastAlong.forall_hasDiscrepancyAtLeastAlong_iff_unboundedDiscrepancyAlong
        (g := out.g) (d := out.d)).2 hunb

/-- Unboundedness of reduced discrepancy is equivalent to unboundedness of the bundled offset family.

The suffix `_lt` is legacy: the witness is `B < ...` (i.e. ‚Äúgreater than B‚ÄĚ).
-/
@[deprecated "Use `unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt` (witnesses are of the form `B < discOffset ...`)." (since := "2026-03-24")]
theorem unboundedDiscrepancyAlong_iff_forall_exists_discOffset_lt (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d ‚ÜĒ (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < discOffset f out.d out.m n) := by
  constructor
  ¬∑ intro hunb B
    rcases hunb B with ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    simpa [discrepancy_eq_discOffset_via_contract (out := out) (n := n)] using hn
  ¬∑ intro hunb B
    rcases hunb B with ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    simpa [discrepancy_eq_discOffset_via_contract (out := out) (n := n)] using hn

/-- Preferred naming for `unboundedDiscrepancyAlong_iff_forall_exists_discOffset_lt`.

The witnesses have the form `B < discOffset ...`, so we use the suffix `_gt` (‚Äúgreater than B‚ÄĚ).
-/
theorem unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d ‚ÜĒ (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < discOffset f out.d out.m n) := by
  constructor
  ¬∑ intro hunb B
    rcases hunb B with ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    simpa [discrepancy_eq_discOffset_via_contract (out := out) (n := n)] using hn
  ¬∑ intro hunb B
    rcases hunb B with ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    simpa [discrepancy_eq_discOffset_via_contract (out := out) (n := n)] using hn

/-- Inequality-direction variant of `unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt`,
written as `discOffset ... > B`.

Many consumers prefer this normal form so they can `simp [gt_iff_lt]` at the call site.
-/
theorem unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt' (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d ‚ÜĒ
      (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, discOffset f out.d out.m n > B) := by
  simpa [gt_iff_lt] using
    (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (f := f) (out := out))

/-- Packaged predicate form: reduced-step unbounded discrepancy is equivalent to unboundedness of the
bundled offset discrepancy family for `f`.
-/
theorem unboundedDiscrepancyAlong_iff_unboundedDiscOffset (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d ‚ÜĒ UnboundedDiscOffset f out.d out.m := by
  simpa [UnboundedDiscOffset] using
    (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (f := f) (out := out))

/-- Nucleus-level variant of `unboundedDiscrepancyAlong_iff_forall_exists_discOffset_lt`. -/
@[deprecated "Use `unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumOffset_gt` (witnesses are of the form `B < Int.natAbs ...`)." (since := "2026-03-24")]
theorem unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumOffset_lt (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d ‚ÜĒ
      (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < Int.natAbs (apSumOffset f out.d out.m n)) := by
  constructor
  ¬∑ intro hunb
    have hdisc : ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < discOffset f out.d out.m n :=
      (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (f := f) (out := out)).1 hunb
    intro B
    rcases hdisc B with ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©
  ¬∑ intro hunb
    refine
      (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (f := f) (out := out)).2 ?_
    intro B
    rcases hunb B with ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©

/-- Preferred naming for `unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumOffset_lt`.

The witnesses have the form `B < Int.natAbs ...`, so we use the suffix `_gt` (‚Äúgreater than B‚ÄĚ).
-/
theorem unboundedDiscrepancyAlong_iff_forall_exists_natAbs_apSumOffset_gt (out : ReductionOutput f) :
    UnboundedDiscrepancyAlong out.g out.d ‚ÜĒ
      (‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < Int.natAbs (apSumOffset f out.d out.m n)) := by
  constructor
  ¬∑ intro hunb
    have hdisc : ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < discOffset f out.d out.m n :=
      (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (f := f) (out := out)).1 hunb
    intro B
    rcases hdisc B with ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©
  ¬∑ intro hunb
    refine
      (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (f := f) (out := out)).2 ?_
    intro B
    rcases hunb B with ‚ü®n, hn‚ü©
    exact ‚ü®n, hn‚ü©

/-- If the bundled offset discrepancies are unbounded, then `f` cannot have globally bounded discrepancy. -/
theorem not_boundedDiscrepancy_of_forall_exists_discOffset_gt (out : ReductionOutput f)
    (hunb : ‚ąÄ B : ‚Ąē, ‚ąÉ n : ‚Ąē, B < discOffset f out.d out.m n) :
    ¬¨ BoundedDiscrepancy f := by
  exact
    Tao2015.not_boundedDiscrepancy_of_forall_exists_discOffset_gt (f := f) (d := out.d) (m := out.m)
      out.hd hunb

/-- If reduced discrepancy along `out.d` is unbounded, then `f` cannot have globally bounded discrepancy.

This is just `not_boundedDiscrepancy_of_forall_exists_discOffset_gt` composed with the Stage-1
transport equivalence `unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt`.
-/
theorem not_boundedDiscrepancy_of_unboundedDiscrepancyAlong (out : ReductionOutput f)
    (hunb : UnboundedDiscrepancyAlong out.g out.d) :
    ¬¨ BoundedDiscrepancy f := by
  refine ReductionOutput.not_boundedDiscrepancy_of_forall_exists_discOffset_gt (f := f) (out := out) ?_
  exact (unboundedDiscrepancyAlong_iff_forall_exists_discOffset_gt (f := f) (out := out)).1 hunb

end ReductionOutput

/-- If an offset discrepancy family is unbounded (packaged form), then `f` cannot have globally
bounded discrepancy.

This is just `not_boundedDiscrepancy_of_forall_exists_discOffset_gt` with `UnboundedDiscOffset`
unfolded.
-/
theorem not_boundedDiscrepancy_of_unboundedDiscOffset (f : ‚Ąē ‚Üí ‚Ą§) {d m : ‚Ąē} (hd : d > 0)
    (hunb : UnboundedDiscOffset f d m) :
    ¬¨ BoundedDiscrepancy f := by
  refine
    Tao2015.not_boundedDiscrepancy_of_forall_exists_discOffset_gt (f := f) (d := d) (m := m) hd ?_
  simpa [UnboundedDiscOffset] using hunb

/-- Variant of `not_boundedDiscrepancy_of_unboundedDiscOffset` with the step-size side condition
written as `1 ‚Č§ d`.

Many later stages prefer `1 ‚Č§ d` to avoid rewriting `d > 0`.
-/
theorem not_boundedDiscrepancy_of_unboundedDiscOffset_one_le (f : ‚Ąē ‚Üí ‚Ą§) {d m : ‚Ąē} (hd : 1 ‚Č§ d)
    (hunb : UnboundedDiscOffset f d m) :
    ¬¨ BoundedDiscrepancy f := by
  have hd' : d > 0 := lt_of_lt_of_le Nat.zero_lt_one hd
  exact not_boundedDiscrepancy_of_unboundedDiscOffset (f := f) (d := d) (m := m) hd' hunb

/-- Variant of `not_boundedDiscrepancy_of_unboundedDiscOffset` with the step-size side condition
written as `d ‚Č† 0`.

This is often the natural hypothesis produced by stage output records.
-/
theorem not_boundedDiscrepancy_of_unboundedDiscOffset_ne_zero (f : ‚Ąē ‚Üí ‚Ą§) {d m : ‚Ąē} (hd : d ‚Č† 0)
    (hunb : UnboundedDiscOffset f d m) :
    ¬¨ BoundedDiscrepancy f := by
  have hd' : d > 0 := Nat.pos_of_ne_zero hd
  exact not_boundedDiscrepancy_of_unboundedDiscOffset (f := f) (d := d) (m := m) hd' hunb

end Tao2015

